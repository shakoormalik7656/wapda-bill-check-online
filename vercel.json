{
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(og-image\\.jpg|og-image\\.jpeg|favicon\\.svg)",
      "headers": { "Cache-Control": "public, max-age=86400, stale-while-revalidate=604800" },
      "continue": true
    },
    {
      "src": "/(sitemap\\.xml|robots\\.txt)",
      "headers": { "Cache-Control": "public, max-age=86400" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "headers": {
        "X-Frame-Options": "SAMEORIGIN",
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Strict-Transport-Security": "max-age=63072000; includeSubDomains; preload",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()",
        "Content-Security-Policy": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; frame-src 'self' https://bill.pitc.com.pk https://www.bill.pitc.com.pk blob:;",
        "X-DNS-Prefetch-Control": "on"
      },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
